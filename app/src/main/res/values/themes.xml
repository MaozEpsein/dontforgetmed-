<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DontForgetMed.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.DontForgetMed</item>
    </style>

    <style name="Theme.DontForgetMed" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.DontForgetMed.Transparent" parent="android:Theme.Translucent.NoTitleBar">
        <item name="android:windowBackground">#99000000</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
</resources>
